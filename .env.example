DISCORD_BOT_TOKEN=

# Optional. If omitted, the bot responds only when mentioned.
DISCORD_CHANNEL_ID=

# Optional. Start Codex separately with:
# codex app-server --listen ws://127.0.0.1:4500
CODEX_APP_SERVER_URL=ws://127.0.0.1:4500

# Optional. Path Codex should use as the conversation cwd.
CODEX_CWD=

# Optional. Persists Discord channel -> Codex thread mappings.
SESSION_STORE_PATH=.sessions.json
